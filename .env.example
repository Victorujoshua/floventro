# ─── Marketing site (Supabase — waitlist project) ───────────────────────────
# Used by the public landing page (floventro.com) to store waitlist signups.
# This is a SEPARATE Supabase project from the app below.
NEXT_PUBLIC_SUPABASE_URL=https://your-marketing-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-marketing-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-marketing-service-role-key
NEXT_PUBLIC_SITE_URL=https://floventro.com

# ─── App (Supabase — application project) ────────────────────────────────────
# Used by the app (app.floventro.com) for auth, memberships, inventory, etc.
# This is a SEPARATE Supabase project from the marketing site above.
NEXT_PUBLIC_APP_SUPABASE_URL=https://your-app-project.supabase.co
NEXT_PUBLIC_APP_SUPABASE_ANON_KEY=your-app-anon-key
APP_SUPABASE_SERVICE_ROLE_KEY=your-app-service-role-key
# Local: http://localhost:3000 — Production: https://app.floventro.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to "production" in Vercel; leave as "development" locally.
NEXT_PUBLIC_APP_ENV=development

# ─── Email (ZeptoMail — transactional) ───────────────────────────────────────
# See docs/zeptomail-setup.md for how to obtain these values.
# ZEPTOMAIL_TOKEN: the Send Mail Token from your ZeptoMail Mail Agent.
ZEPTOMAIL_TOKEN=your-zeptomail-send-mail-token
ZEPTOMAIL_FROM_ADDRESS=hello@floventro.com
ZEPTOMAIL_FROM_NAME=Floventro
# Template key from the ZeptoMail invite email template.
ZEPTOMAIL_INVITE_TEMPLATE_KEY=your-invite-template-key
